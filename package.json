{
  "name": "demo-angular-material-rxdb",
  "version": "0.0.0",
  "author": {
    "name": "Dominik Hladík",
    "email": "dominik.hladik@seznam.cz",
    "url": "https://github.com/Celtian"
  },
  "license": "MIT",
  "private": true,
  "description": "Demo of angular & rxdb",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint && yarn lint:styles",
    "lint:styles": "stylelint \"src/**/*.scss\"",
    "create-version": "npx package-version-info -o src/app/version.ts",
    "postinstall": "yarn create-version",
    "prepare": "husky",
    "i18n:extract-regex": "ngx-i18n-extract-regex-cli extract --library ngx-translate",
    "i18n:extract": "ngx-translate-extract --input ./src --output ./src/assets/i18n/*.json --clean --sort --format namespaced-json --marker _ --format-indentation '  ' --string-as-default-value '███'",
    "fix-vulnerabilities": "npx yarn-audit-fix && npx browserslist --update-db"
  },
  "dependencies": {
    "@angular/animations": "^22.0.2",
    "@angular/cdk": "^22.0.2",
    "@angular/common": "^22.0.2",
    "@angular/compiler": "^22.0.2",
    "@angular/core": "^22.0.2",
    "@angular/forms": "^22.0.2",
    "@angular/material": "^22.0.2",
    "@angular/platform-browser": "^22.0.2",
    "@angular/platform-browser-dynamic": "^22.0.2",
    "@angular/router": "^22.0.2",
    "@gilsdav/ngx-translate-router": "^8.0.0",
    "@gilsdav/ngx-translate-router-http-loader": "^2.0.0",
    "@ngx-translate/core": "17",
    "@ngx-translate/http-loader": "17",
    "lodash-es": "^4.18.1",
    "ngx-app-version": "^2.2.1",
    "ngx-fixed-footer": "^4.1.1",
    "ngx-translate-version": "^5.0.1",
    "rxdb": "^15.39.0",
    "rxjs": "^7.8.2",
    "tslib": "^2.8.1",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.4",
    "@angular/compiler-cli": "^22.0.2",
    "@biesbjerg/ngx-translate-extract-marker": "^1.0.0",
    "@commitlint/cli": "^21.1.0",
    "@commitlint/config-angular": "^21.1.0",
    "@eslint/js": "^10.0.1",
    "@types/lodash-es": "^4.17.12",
    "@vendure/ngx-translate-extract": "^10.2.0",
    "angular-eslint": "22.0.0",
    "autoprefixer": "^10.5.1",
    "eslint": "^10.5.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "package-version-info": "^0.0.6",
    "postcss": "^8.5.15",
    "prettier": "^3.8.4",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "tailwindcss": "^3.4.15",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  },
  "engines": {
    "node": ">=24 <26",
    "npm": "please-use-yarn"
  },
  "resolutions": {
    "@typescript-eslint/utils": "8.62.0",
    "baseline-browser-mapping": "^2.10.0"
  }
}
